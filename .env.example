# === Nakili kuwa .env au .env.local — usicommit ===

# Jina la tovuti (linaonekana kwenye kichwa)
SITE_NAME=Betmakini

# Topic ya FCM (sawa na Android / miradi yako)
FCM_TOPIC=BETMAKINI

# Saa za ratiba ya kila siku (kanda ya wakati)
SCHEDULE_TZ=Africa/Nairobi

# Njia ya faili ya JSON ya ratiba. PC: data/schedules.json. Vercel: bila hii, mradi unaandika /tmp/web-notify-schedules.json
# SCHEDULE_DB_PATH=data/schedules.json
# Jaribio la UI kama Vercel (hifadhi ya muda mfupi): SCHEDULE_EPHEMERAL=1

# Lazima ujaze thamani halisi (si uache tupu) — vinginevyo API inazuiliwa. Dev bila nenosiri: ADMIN_AUTH_OPEN=1
ADMIN_SECRET=

# Dev tu — API wazi bila ADMIN_SECRET. Usitumie kwenye mtandao wa umma.
# ADMIN_AUTH_OPEN=1

# Siri ya cron (Vercel Cron inatuma Bearer hii). Lazima kwenye Vercel ukijiunga na cron.
CRON_SECRET=

# --- Firebase / Google ---
# PC: njia ya FAILI tu (si maudhui ya JSON)
GOOGLE_APPLICATION_CREDENTIALS=../service-account.json
# Vercel / env ya mstari: tumia JINA HILI na JSON kamili (mstari mmoja au uliopachikwa)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# Usiweke JSON kwenye GOOGLE_APPLICATION_CREDENTIALS — variable hiyo ni njia ya faili pekee (isipokuwa server inasoma JSON kama mstari wa kuanza na {)

# PORT=3000
