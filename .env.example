# === Nakili kuwa .env au .env.local — usicommit ===

# Jina la tovuti (linaonekana kwenye kichwa)
SITE_NAME=Betmakini

# Topic ya FCM (sawa na Android / miradi yako)
FCM_TOPIC=BETMAKINI

# Saa za ratiba ya kila siku (kanda ya wakati)
SCHEDULE_TZ=Africa/Nairobi

# Njia ya faili ya JSON ya ratiba (chaguo — chaguo-msingi: data/schedules.json)
# SCHEDULE_DB_PATH=data/schedules.json

# Nenosiri la kuongeza/futa ratiba kwenye API (pendekezwa production). Ukibaki tupu, API ya ratiba wazi (hatari ikiwa tovuti ni ya umma).
ADMIN_SECRET=

# Siri ya cron (Vercel Cron inatuma Bearer hii). Lazima kwenye Vercel ukijiunga na cron.
CRON_SECRET=

# --- Firebase / Google ---
GOOGLE_APPLICATION_CREDENTIALS=../service-account.json
# Au Vercel:
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# PORT=3000
