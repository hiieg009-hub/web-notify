# === Betmakini (b-et-makini) — nakili kuwa .env au .env.local ===
# Usicommit .env / .env.local (ziko kwenye .gitignore)

# --- Chaguo 1 (rahisi kwa test ndani ya PC) ---
# Nakili service-account.json yako ndani ya folda hii ya web-notify,
# au weka njia kamili. Mfano ikiwa faili iko folda ya juu (betmakini):
GOOGLE_APPLICATION_CREDENTIALS=../service-account.json

# --- Chaguo 2 (kama Vercel — mstari mmoja, hakuna spaces za ziada mwanzoni) ---
# Toa alama ya # mbele ukijaza thamani halisi. Usishare funguo hadharani.
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"b-et-makini","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk-fbsvc@b-et-makini.iam.gserviceaccount.com","client_id":"102509297783117511151","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"https://www.googleapis.com/robot/v1/metadata/x509/firebase-adminsdk-fbsvc%40b-et-makini.iam.gserviceaccount.com","universe_domain":"googleapis.com"}

# Topic ya FCM — thabiti upande wa server (mteja hawezi kuibadilisha kwa API)
FCM_TOPIC=BETMAKINI

# Port ya server ya ndani (chaguo)
# PORT=3000
